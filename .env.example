# Environment Variables - Copy this to .env and fill in your values

# Zoho Recruit Developer Credentials (OAuth 2.0)
ZOHO_CLIENT_ID=your-client-id
ZOHO_CLIENT_SECRET=your-client-secret
ZOHO_REFRESH_TOKEN=your-refresh-token

# Zoho API Base URL (adjust for EU, IN, CN if needed)
ZOHO_BASE_URL=https://recruit.zoho.com/recruit/v2
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
